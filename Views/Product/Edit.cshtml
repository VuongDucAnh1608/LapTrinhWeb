@model Website_QuanLyKhoHangThucPham.ViewModels.ProductViewModel
@{ ViewData["Title"] = "Sửa sản phẩm"; }
<div class="sc-card" style="max-width:820px;">
  <div class="card-header"><i class="fa fa-pen me-2" style="color:var(--sc-orange);"></i>Chỉnh sửa: @Model.Name</div>
  <div class="p-4">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
      @if(Model.ExistingImageUrl!=null){
        <div class="mb-3 d-flex align-items-center gap-3">
          <img src="@Model.ExistingImageUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #eee;"/>
          <div class="text-muted small">Ảnh hiện tại từ Cloudinary</div>
        </div>
      }
      <div class="row g-3">
        <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"/></div>
        <div class="col-md-4"><label asp-for="SKU" class="form-label"></label><input asp-for="SKU" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="CategoryId" class="form-label"></label>
          @Html.DropDownListFor(m=>m.CategoryId,(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories,"-- Chọn danh mục --",new{@class="form-select"})</div>
        <div class="col-md-6"><label asp-for="SupplierId" class="form-label"></label>
          @Html.DropDownListFor(m=>m.SupplierId,(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Suppliers,"-- Chọn NCC --",new{@class="form-select"})</div>
        <div class="col-md-3"><label asp-for="Unit" class="form-label"></label><input asp-for="Unit" class="form-control"/></div>
        <div class="col-md-3"><label asp-for="MinStockLevel" class="form-label"></label><input asp-for="MinStockLevel" class="form-control" type="number"/></div>
        <div class="col-md-3"><label asp-for="CostPrice" class="form-label"></label><input asp-for="CostPrice" class="form-control" type="number" step="1000"/></div>
        <div class="col-md-3"><label asp-for="SellPrice" class="form-label"></label><input asp-for="SellPrice" class="form-control" type="number" step="1000"/></div>
        <div class="col-md-8"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
        <div class="col-md-4"><label asp-for="ImageFile" class="form-label">Đổi ảnh (tuỳ chọn)</label><input asp-for="ImageFile" class="form-control" type="file" accept="image/*"/></div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-sc-primary"><i class="fa fa-save me-1"></i>Cập nhật</button>
        <a asp-action="Index" class="btn btn-sc-outline">Hủy</a>
      </div>
    </form>
  </div>
</div>
