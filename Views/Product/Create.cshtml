@model Website_QuanLyKhoHangThucPham.ViewModels.ProductViewModel
@{ ViewData["Title"] = "Thêm sản phẩm"; }
<div class="sc-card" style="max-width:820px;">
  <div class="card-header"><i class="fa fa-plus me-2" style="color:var(--sc-orange);"></i>Thêm sản phẩm mới</div>
  <div class="p-4">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
      <div class="row g-3">
        <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"/><span asp-validation-for="Name" class="text-danger small"></span></div>
        <div class="col-md-4"><label asp-for="SKU" class="form-label"></label><input asp-for="SKU" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="CategoryId" class="form-label"></label>
          @Html.DropDownListFor(m=>m.CategoryId,(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories,"-- Chọn danh mục --",new{@class="form-select"})
          <span asp-validation-for="CategoryId" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="SupplierId" class="form-label"></label>
          @Html.DropDownListFor(m=>m.SupplierId,(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Suppliers,"-- Chọn NCC --",new{@class="form-select"})
          <span asp-validation-for="SupplierId" class="text-danger small"></span></div>
        <div class="col-md-3"><label asp-for="Unit" class="form-label"></label><input asp-for="Unit" class="form-control"/></div>
        <div class="col-md-3"><label asp-for="MinStockLevel" class="form-label"></label><input asp-for="MinStockLevel" class="form-control" type="number"/></div>
        <div class="col-md-3"><label asp-for="CostPrice" class="form-label"></label><input asp-for="CostPrice" class="form-control" type="number" step="1000"/></div>
        <div class="col-md-3"><label asp-for="SellPrice" class="form-label"></label><input asp-for="SellPrice" class="form-control" type="number" step="1000"/></div>
        <div class="col-md-8"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
        <div class="col-md-4"><label asp-for="ImageFile" class="form-label"></label><input asp-for="ImageFile" class="form-control" type="file" accept="image/*"/>
          <div class="form-text"><i class="fa fa-cloud me-1 text-success"></i>Ảnh lưu trên Cloudinary</div></div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-sc-primary"><i class="fa fa-save me-1"></i>Lưu sản phẩm</button>
        <a asp-action="Index" class="btn btn-sc-outline">Hủy</a>
      </div>
    </form>
  </div>
</div>
