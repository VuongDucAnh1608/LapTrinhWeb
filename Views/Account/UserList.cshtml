@using Microsoft.AspNetCore.Identity
@model IEnumerable<(Website_QuanLyKhoHangThucPham.Models.ApplicationUser User, IList<string> Roles)>
@{ ViewData["Title"] = "Danh sách tài khoản"; }
<div class="d-flex justify-content-between align-items-center mb-4">
<h4 class="fw-bold mb-0"><i class="fa fa-users me-2 text-primary"></i>Tài khoản hệ thống</h4>
<a asp-action="Register" class="btn btn-primary"><i class="fa fa-plus me-2"></i>Tạo tài khoản</a>
</div>
<div class="card"><div class="card-body p-0">
<table class="table table-hover mb-0">
<thead class="table-light"><tr>
<th>Họ tên</th><th>Email</th><th>Số điện thoại</th><th>Vai trò</th><th>Trạng thái</th>
</tr></thead>
<tbody>
@foreach(var item in Model)
{
 var user = item.User; var roles = item.Roles; 
<tr>
<td class="fw-semibold">@user.FullName</td>
<td>@user.Email</td>
<td>@user.PhoneNumber</td>
<td>@foreach(var r in roles){ <span class="badge bg-info me-1">@r</span> }</td>
<td><span class="badge @(user.IsActive?"bg-success":"bg-secondary")">@(user.IsActive?"Hoạt động":"Đã khóa")</span></td>
</tr>
}
</tbody>
</table>
</div></div>
